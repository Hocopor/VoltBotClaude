# ============================================================
# VOLTAGE TRADING BOT — PRODUCTION ENVIRONMENT
# ============================================================

# --- Database ---
POSTGRES_DB=voltage
POSTGRES_USER=voltage
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- Application ---
SECRET_KEY=CHANGE_ME_SECRET_KEY_MIN_32_CHARS
APP_NAME=VOLTAGE
DEBUG=false

# --- Bybit API (Mainnet) ---
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret
BYBIT_TESTNET=false

# --- DeepSeek AI ---
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- OpenAI / Codex (for OAuth flow) ---
OPENAI_CLIENT_ID=your_openai_client_id
OPENAI_CLIENT_SECRET=your_openai_client_secret
OPENAI_REDIRECT_URI=https://yourdomain.com/api/auth/codex/callback

# --- Cloudflare Tunnel ---
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token

# --- Frontend URLs ---
REACT_APP_API_URL=/api
REACT_APP_WS_URL=/ws

# --- CORS ---
ALLOWED_ORIGINS=https://yourdomain.com

# --- Trading Defaults ---
DEFAULT_PAPER_BALANCE=10000.0
DEFAULT_BACKTEST_BALANCE=10000.0

# --- Logging ---
LOG_LEVEL=INFO
