# ============================================================
# VOLTAGE TRADING BOT — PRODUCTION ENVIRONMENT
# ============================================================

# --- Database ---
POSTGRES_DB=voltage
POSTGRES_USER=voltage
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- Application ---
SECRET_KEY=CHANGE_ME_SECRET_KEY_MIN_32_CHARS
APP_NAME=VOLTAGE
DEBUG=false
APP_AUTH_LOGIN=admin
APP_AUTH_PASSWORD_HASH=$2b$12$replace_with_bcrypt_hash
APP_AUTH_COOKIE_SECURE=true
APP_AUTH_SESSION_TTL_HOURS=24

# DATABASE_URL, REDIS_URL and ENV_FILE_PATH are injected by docker-compose.
# They are intentionally omitted from this file.

# --- Bybit API (Mainnet) ---
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret
BYBIT_TESTNET=false
BYBIT_REQUEST_TIMEOUT=20

# --- DeepSeek AI ---
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- OpenAI / Codex (for OAuth flow) ---
OPENAI_CLIENT_ID=your_openai_client_id
OPENAI_CLIENT_SECRET=your_openai_client_secret
OPENAI_REDIRECT_URI=https://yourdomain.com/api/auth/codex/callback

# --- Cloudflare Tunnel ---
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token

# --- Local origin port for nginx ---
APP_PORT=8088

# --- CORS ---
ALLOWED_ORIGINS=https://yourdomain.com

# --- Logging ---
LOG_LEVEL=INFO
